COMPOSE_PROJECT_NAME=xiyangyang-clock

POSTGRES_DB=voice_calendar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_PORT=5432

REDIS_PORT=6379

API_PORT=8000
FRONTEND_PORT=5173

APP_ENV=docker
APP_NAME=Xiyangyang Clock
JWT_SECRET=replace-with-local-jwt-secret
TIMEZONE=Asia/Shanghai
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
# Compatibility aliases for OpenAI-compatible proxy providers:
# API_BASE_URL=https://api.openai.com/v1
# API_KEY=
WS_HEARTBEAT_INTERVAL=30
REMINDER_SCAN_INTERVAL=60

VITE_API_BASE_URL=http://localhost:5173
VITE_WS_URL=ws://localhost:5173/ws
